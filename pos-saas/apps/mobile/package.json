{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~54.0.0",
    "expo-av": "^16.0.8",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-print": "^15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "typescript": "~5.9.3"
  },
  "scripts": {
    "start": "expo start",
    "start:dev": "copy .env.development .env && expo start --clear",
    "start:prod": "copy .env.production .env && expo start --clear",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "eas build --platform android --profile preview",
    "build:apk:local": "eas build --platform android --profile preview --local",
    "build:prod": "copy .env.production .env && eas build --platform android --profile production",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\""
  },
  "private": true
}
