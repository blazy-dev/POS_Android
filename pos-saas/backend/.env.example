PROJECT_NAME="POS SaaS Android-First"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Seguridad y JWT (Generar una clave segura en producción usando: openssl rand -hex 32)
SECRET_KEY="development_secret_key_change_me_in_production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 días (para facilitar persistencia offline inicial)

# Base de datos: Conexión PostgreSQL (Supabase / Railway)
# Reemplazar con tu URL de conexión de Supabase (directa a puerto 5432 o transacción vía puerto 6543)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# JWT Secret de Supabase (Se obtiene en Configuración de API en el dashboard de Supabase)
SUPABASE_JWT_SECRET="YOUR_SUPABASE_JWT_SECRET"
