PROJECT_NAME="POS SaaS Android-First"
API_V1_STR="/api/v1"
ENVIRONMENT="development"

# Seguridad y JWT (Generar una clave segura en producción usando: openssl rand -hex 32)
SECRET_KEY="development_secret_key_change_me_in_production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 días (para facilitar persistencia offline inicial)

# Base de datos: SQLite para desarrollo local, PostgreSQL para producción/Railway
# Desarrollo (SQLite): sqlite:///./test.db
# Producción (PostgreSQL): postgresql://usuario:password@localhost:5432/dbname
DATABASE_URL="sqlite:///./test.db"

# Autenticación de Google (Requerido para producción)
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
